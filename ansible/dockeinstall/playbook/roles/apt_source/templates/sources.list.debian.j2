# {{ apt_source_name }} mirror for Debian
# generated by Ansible

{% set deb_major = ansible_distribution_major_version | int %}
{% set components = "main contrib non-free" %}
{% if deb_major >= 12 %}
{% set components = "main contrib non-free non-free-firmware" %}
{% endif %}

deb {{ apt_mirrors[apt_source_name].debian_base }} {{ ansible_distribution_release }} {{ components }}
{% if apt_with_src %}
deb-src {{ apt_mirrors[apt_source_name].debian_base }} {{ ansible_distribution_release }} {{ components }}
{% endif %}

{% if deb_major < 10 %}
deb {{ apt_mirrors[apt_source_name].debian_security }} {{ ansible_distribution_release }}/updates {{ components }}
{% if apt_with_src %}
deb-src {{ apt_mirrors[apt_source_name].debian_security }} {{ ansible_distribution_release }}/updates {{ components }}
{% endif %}
{% else %}
deb {{ apt_mirrors[apt_source_name].debian_security }} {{ ansible_distribution_release }}-security {{ components }}
{% if apt_with_src %}
deb-src {{ apt_mirrors[apt_source_name].debian_security }} {{ ansible_distribution_release }}-security {{ components }}
{% endif %}
{% endif %}

deb {{ apt_mirrors[apt_source_name].debian_base }} {{ ansible_distribution_release }}-updates {{ components }}
{% if apt_with_src %}
deb-src {{ apt_mirrors[apt_source_name].debian_base }} {{ ansible_distribution_release }}-updates {{ components }}
{% endif %}

deb {{ apt_mirrors[apt_source_name].debian_base }} {{ ansible_distribution_release }}-backports {{ components }}
{% if apt_with_src %}
deb-src {{ apt_mirrors[apt_source_name].debian_base }} {{ ansible_distribution_release }}-backports {{ components }}
{% endif %}
